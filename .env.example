# Your Intervals.icu API key (found in Settings > API)
INTERVALS_API_KEY=your_api_key_here

# Your Intervals.icu athlete ID (found in the URL when logged in, e.g. i12345)
INTERVALS_ATHLETE_ID=your_athlete_id_here

# Secret token to protect the /sse endpoint (generate with: openssl rand -hex 32)
# Add this as a query param when connecting: https://your-app.railway.app/sse?token=<value>
# Leave unset to disable auth (local dev only)
MCP_AUTH_TOKEN=

# Port to listen on (Railway sets this automatically)
PORT=8000
